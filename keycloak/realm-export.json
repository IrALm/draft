{
  "realm": "erp-comptable",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 300,

  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,

  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,

  "roles": {
    "realm": [
      { "name": "ADMIN", "description": "Administrateur de l'entite (chef d'entreprise)" },
      { "name": "COMPTABLE", "description": "Gestion comptable" },
      { "name": "RH", "description": "Gestion des ressources humaines" },
      { "name": "ACHATS", "description": "Gestion des achats" },
      { "name": "CAISSIER", "description": "Gestion de caisse" },
      { "name": "LECTURE_SEULE", "description": "Acces en lecture seule" }
    ]
  },

  "clients": [
    {
      "clientId": "api-compta-admin",
      "name": "API Compta - Admin (service account)",
      "description": "Client de service dedie, utilise uniquement par KeycloakAdminClient (backend) pour creer/gerer les utilisateurs via l'Admin REST API. Ne doit jamais etre utilise pour authentifier un utilisateur final.",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "${KC_APP_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "erp-comptable-app",
      "name": "API Compta - Application",
      "description": "Client utilise par le frontend / les clients API pour authentifier les utilisateurs finaux (Authorization Code). directAccessGrantsEnabled active en dev pour faciliter les tests (Postman, etc.) - a desactiver en production.",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["+"]
    },
    {
      "clientId": "api-compta-bff",
      "name": "API Compta - BFF (login/logout backend-mediated)",
      "description": "Client confidentiel first-party (ROPC) d'api-compta : echange les identifiants utilisateur contre des tokens, les rafraichit/revoque. JWT jamais transmis au frontend (cookie opaque). Ne supporte pas le MFA - revoir avant CONFIGURE_TOTP.",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "${KC_BFF_CLIENT_SECRET}",
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "authorizationServicesEnabled": false
    }
  ],

  "users": [
    {
      "username": "service-account-api-compta-admin",
      "enabled": true,
      "serviceAccountClientId": "api-compta-admin",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "view-realm"]
      }
    }
  ]
}
